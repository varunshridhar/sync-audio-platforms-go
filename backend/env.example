# Application mode: use "production" in deployed environments.
APP_ENV=development
# Backend HTTP port inside container/host.
PORT=8080
# Only this origin is allowed by backend CORS middleware.
ALLOWED_ORIGIN=http://localhost:3000
# Store backend: "firestore" or "sqlite".
STORE_PROVIDER=sqlite
# Local SQLite file path used when STORE_PROVIDER=sqlite.
SQLITE_PATH=/tmp/sync-audio-platforms.db
# HMAC secret for session signing (minimum 32 chars).
SESSION_HMAC_KEY=replace-with-32-byte-minimum-secret
# Base64 value that decodes to exactly 32 bytes (AES-256 key).
TOKEN_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
# Firestore GCP project ID for database access (required only when STORE_PROVIDER=firestore).
FIRESTORE_PROJECT_ID=your-gcp-project-id
# Per-IP request cap for basic abuse protection.
DEFAULT_RATE_LIMIT_PER_MIN=120
# Per-IP signup/login attempts allowed per hour.
SIGNUP_RATE_LIMIT_PER_HOUR=10
# Comma-separated admin emails allowed to approve pending users.
ADMIN_EMAILS=dev@example.com
# Cloudflare Turnstile secret for bot protection on signup.
TURNSTILE_SECRET_KEY=replace-with-turnstile-secret
# Optional comma-separated invite/access codes that auto-approve users.
SIGNUP_ACCESS_CODES=Ryanthisisforoouuuuu
# Maximum total uses allowed per access code across all users (set 1 for one-time codes).
ACCESS_CODE_MAX_USES=1
# Lock access-code brute force after N failed attempts (per IP+email key).
ACCESS_CODE_MAX_FAILURES=5
# Lockout duration in minutes after too many failed access-code attempts.
ACCESS_CODE_LOCKOUT_MINUTES=15

