{
    "info": {
        "name": "Sync Audio Platforms API",
        "description": "API collection for syncing audio between different platforms",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "App Endpoints",
            "item": [
                {
                    "name": "Health",
                    "item": [
                        {
                            "name": "Check Health",
                            "request": {
                                "method": "GET",
                                "header": [],
                                "url": {
                                    "raw": "{{base_url}}/health",
                                    "host": ["{{base_url}}"],
                                    "path": ["health"]
                                }
                            }
                        }
                    ]
                },
                {
                    "name": "Authentication",
                    "item": [
                        {
                            "name": "Login with Spotify",
                            "request": {
                                "method": "GET",
                                "header": [],
                                "url": {
                                    "raw": "{{base_url}}/auth/login",
                                    "host": ["{{base_url}}"],
                                    "path": ["auth", "login"]
                                }
                            }
                        },
                        {
                            "name": "Spotify Callback",
                            "request": {
                                "method": "GET",
                                "header": [],
                                "url": {
                                    "raw": "{{base_url}}/callback?code={{code}}&state={{state}}",
                                    "host": ["{{base_url}}"],
                                    "path": ["callback"],
                                    "query": [
                                        {
                                            "key": "code",
                                            "value": "{{code}}"
                                        },
                                        {
                                            "key": "state",
                                            "value": "{{state}}"
                                        }
                                    ]
                                }
                            }
                        }
                    ]
                },
                {
                    "name": "Spotify",
                    "item": [
                        {
                            "name": "Get User Playlists",
                            "request": {
                                "method": "GET",
                                "header": [
                                    {
                                        "key": "Authorization",
                                        "value": "Bearer {{spotify_access_token}}",
                                        "type": "text"
                                    }
                                ],
                                "url": {
                                    "raw": "{{base_url}}/playlists",
                                    "host": ["{{base_url}}"],
                                    "path": ["playlists"]
                                }
                            }
                        }
                    ]
                }
            ]
        },
        {
            "name": "Spotify Direct API",
            "item": [
                {
                    "name": "Get Current User Profile",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{spotify_access_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "https://api.spotify.com/v1/me",
                            "host": ["api.spotify.com"],
                            "path": ["v1", "me"]
                        }
                    }
                },
                {
                    "name": "Get User's Playlists",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{spotify_access_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "https://api.spotify.com/v1/me/playlists?limit=50",
                            "host": ["api.spotify.com"],
                            "path": ["v1", "me", "playlists"],
                            "query": [
                                {
                                    "key": "limit",
                                    "value": "50"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Get Playlist Tracks",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{spotify_access_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "https://api.spotify.com/v1/playlists/{{playlist_id}}/tracks",
                            "host": ["api.spotify.com"],
                            "path": ["v1", "playlists", "{{playlist_id}}", "tracks"]
                        }
                    }
                },
                {
                    "name": "Get User's Saved Tracks",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{spotify_access_token}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "https://api.spotify.com/v1/me/tracks?limit=50",
                            "host": ["api.spotify.com"],
                            "path": ["v1", "me", "tracks"],
                            "query": [
                                {
                                    "key": "limit",
                                    "value": "50"
                                }
                            ]
                        }
                    }
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8080"
        },
        {
            "key": "spotify_access_token",
            "value": "your_access_token_here"
        },
        {
            "key": "playlist_id",
            "value": "your_playlist_id_here"
        }
    ]
} 